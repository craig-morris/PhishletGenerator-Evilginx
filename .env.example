# AI Configuration (optional - enhances phishlet generation accuracy)
# Provider: openai, anthropic, deepseek, ollama, lmstudio, custom
AI_PROVIDER=deepseek
AI_API_KEY=
AI_MODEL=deepseek/deepseek-chat
# AI_BASE_URL=  # Optional: override the default API base URL

# Ollama example (local, no API key needed):
# AI_PROVIDER=ollama
# AI_MODEL=ollama/llama3
# AI_BASE_URL=http://localhost:11434

# LM Studio example (local, no API key needed):
# AI_PROVIDER=lmstudio
# AI_MODEL=openai/lmstudio-local
# AI_BASE_URL=http://localhost:1234/v1

# Server
DEBUG=false
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# Evilginx
EVILGINX_MIN_VER=3.2.0
